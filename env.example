# =============================================================================
# SuperStack — Environment Example
# =============================================================================
# Copy to .env and fill in your actual secrets:
#   cp env.example .env
#
# Variables marked with :? in docker-compose.yml are REQUIRED for their profile.
# Variables with :- have safe defaults and are optional to override.
#
# Quick secret generation:
#   openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — SurrealDB (Multi-model database)
# Port: 8000 | Always starts
# Endpoint: ws://localhost:8000/rpc  or  http://localhost:8000
# -----------------------------------------------------------------------------
SURREALDB_USER=root
SURREALDB_PASSWORD=CHANGE_ME_strong_password_here
SURREALDB_PORT=8000

# -----------------------------------------------------------------------------
# CORE — Dragonfly (Redis-compatible cache / broker)
# Port: 6379 | Always starts
# Connect: redis-cli -a $DRAGONFLY_PASSWORD -p 6379
# -----------------------------------------------------------------------------
DRAGONFLY_PASSWORD=CHANGE_ME_strong_password_here
DRAGONFLY_PORT=6379
DRAGONFLY_MAX_MEMORY=2gb

# -----------------------------------------------------------------------------
# CORE — NATS (Messaging + JetStream persistence)
# Ports: 4222 (client), 8222 (monitoring UI)
# Always starts
# -----------------------------------------------------------------------------
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# -----------------------------------------------------------------------------
# GATEWAY — Caddy (Reverse proxy + auto-HTTPS)
# Ports: 80, 443 | Profile: gateway
# Set DOMAIN to your real domain for automatic Let's Encrypt certs.
# Use DOMAIN=localhost for local dev (self-signed).
# -----------------------------------------------------------------------------
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com

# -----------------------------------------------------------------------------
# SEARCH — Meilisearch (Full-text search engine)
# Port: 7700 | Profile: search
# REQUIRED: MEILI_MASTER_KEY (min 16 chars in production)
# UI: http://localhost:7700 (protected by master key)
# -----------------------------------------------------------------------------
MEILI_MASTER_KEY=CHANGE_ME_at_least_16_characters_long
MEILI_PORT=7700
MEILI_ENV=production
MEILI_LOG_LEVEL=INFO
MEILI_MAX_INDEXING_MEMORY=1Gb

# -----------------------------------------------------------------------------
# MONITORING — SigNoz (OpenTelemetry: traces + metrics + logs)
# Ports: 3301 (UI), 4317 (OTLP gRPC), 4318 (OTLP HTTP)
# Profile: monitoring
# UI: http://localhost:3301
# REQUIRED: SIGNOZ_CLICKHOUSE_PASSWORD
# -----------------------------------------------------------------------------
SIGNOZ_PORT=3301
SIGNOZ_CLICKHOUSE_DB=signoz_metrics
SIGNOZ_CLICKHOUSE_USER=admin
SIGNOZ_CLICKHOUSE_PASSWORD=CHANGE_ME_strong_password_here
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# -----------------------------------------------------------------------------
# MONITORING — Langfuse (LLM observability, evals, prompt management)
# Port: 3100 | Profile: monitoring
# UI: http://localhost:3100
# REQUIRED: LANGFUSE_DB_PASSWORD, LANGFUSE_NEXTAUTH_SECRET (32+ chars), LANGFUSE_SALT (32+ chars)
# LANGFUSE_INIT_* variables auto-create org/project/user on first boot
# -----------------------------------------------------------------------------
LANGFUSE_PORT=3100
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_strong_password_here
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32
LANGFUSE_NEXTAUTH_URL=http://localhost:3100
LANGFUSE_SALT=CHANGE_ME_run_openssl_rand_base64_32
LANGFUSE_EXPERIMENTAL=false
LANGFUSE_TELEMETRY=false
LANGFUSE_INIT_ORG_ID=superstack
LANGFUSE_INIT_ORG_NAME=SuperStack
LANGFUSE_INIT_PROJECT_ID=default
LANGFUSE_INIT_PROJECT_NAME=Default Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=admin@superstack.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_admin_password_here

# -----------------------------------------------------------------------------
# MONITORING — Beszel (Server + container monitoring hub)
# Port: 8090 | Profile: monitoring
# UI: http://localhost:8090 (set up admin on first visit)
# Deploy beszel-agent on other hosts to monitor them
# -----------------------------------------------------------------------------
BESZEL_PORT=8090

# -----------------------------------------------------------------------------
# MONITORING — Uptime Kuma (Uptime + status page)
# Port: 3200 | Profile: monitoring
# UI: http://localhost:3200 (set up admin on first visit)
# -----------------------------------------------------------------------------
UPTIME_KUMA_PORT=3200

# -----------------------------------------------------------------------------
# WORKFLOWS — Windmill (Scripts + flows + apps platform)
# Port: 8100 | Profile: workflows
# UI: http://localhost:8100
# REQUIRED: WINDMILL_DB_PASSWORD, WINDMILL_SECRET (32+ chars)
# Default superadmin: admin@windmill.dev / changeme (change on first login)
# -----------------------------------------------------------------------------
WINDMILL_PORT=8100
WINDMILL_DB_NAME=windmill
WINDMILL_DB_USER=windmill
WINDMILL_DB_PASSWORD=CHANGE_ME_strong_password_here
WINDMILL_SECRET=CHANGE_ME_run_openssl_rand_base64_32
WINDMILL_BASE_URL=http://localhost:8100

# -----------------------------------------------------------------------------
# EMAIL — Listmonk (Newsletter + mailing list manager)
# Port: 9000 | Profile: email
# UI: http://localhost:9000
# REQUIRED: LISTMONK_DB_PASSWORD, LISTMONK_ADMIN_PASSWORD
# Configure SMTP under Settings > SMTP after first login
# -----------------------------------------------------------------------------
LISTMONK_PORT=9000
LISTMONK_DB_NAME=listmonk
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=CHANGE_ME_strong_password_here
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=CHANGE_ME_admin_password_here

# -----------------------------------------------------------------------------
# STORAGE — SeaweedFS (Distributed object storage, S3-compatible)
# Ports: 9333 (master), 8080 (volume), 8333 (S3 API) | Profile: storage
# S3 endpoint: http://localhost:8333
# Compatible with AWS SDK, MinIO client (mc), rclone, etc.
# -----------------------------------------------------------------------------
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_ACCESS_KEY=CHANGE_ME_access_key
SEAWEEDFS_SECRET_KEY=CHANGE_ME_secret_key

# -----------------------------------------------------------------------------
# STORAGE — Umami (Privacy-focused web analytics)
# Port: 3500 | Profile: storage
# UI: http://localhost:3500
# Default login: admin / umami — CHANGE IMMEDIATELY after first login
# REQUIRED: UMAMI_DB_PASSWORD, UMAMI_APP_SECRET (32+ chars)
# -----------------------------------------------------------------------------
UMAMI_PORT=3500
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=CHANGE_ME_strong_password_here
UMAMI_APP_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# VISUALIZATION — Cube.js (Semantic analytics & data modeling)
# Port: 4000 | Profile: dashboard
# Playground: http://localhost:4001
# REQUIRED: CUBE_API_SECRET (32+ chars)
# Cube.js connects to PostgreSQL/SurrealDB for semantic analytics
# -----------------------------------------------------------------------------
CUBE_PORT=4000
CUBE_PLAYGROUND_PORT=4001
CUBE_API_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# VISUALIZATION — Dozzle (Docker logs aggregator)
# Port: 9999 | Profile: dashboard
# UI: http://localhost:9999
# Real-time log viewer for all containers in the stack
# No auth required (runs in read-only mode via socket mounting)
# -----------------------------------------------------------------------------
DOZZLE_PORT=9999

# -----------------------------------------------------------------------------
# VISUALIZATION — Portainer CE (Container management UI)
# Port: 9443 | Profile: dashboard
# UI: https://localhost:9443 (self-signed HTTPS)
# Full Docker container management, image registry, volumes, etc.
# Set up admin user on first visit
# -----------------------------------------------------------------------------
PORTAINER_PORT=9443
