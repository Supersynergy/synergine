# =============================================================================
# Synergine App — Environment Variables
# =============================================================================
# Copy to .env:  cp env.example .env

# --- App ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# --- Better Auth ---
BETTER_AUTH_SECRET=synergine-dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# --- Database (SQLite via libSQL) ---
DATABASE_URL=file:local.db

# --- Infrastructure (Docker services) ---
SURREALDB_USER=root
SURREALDB_PASS=synergine
SURREALDB_URL=http://localhost:8000

DRAGONFLY_PASS=synergine
DRAGONFLY_URL=redis://:synergine@localhost:6379

NATS_URL=nats://localhost:4222

MEILI_MASTER_KEY=synergine-meili-key
MEILI_URL=http://localhost:7700
